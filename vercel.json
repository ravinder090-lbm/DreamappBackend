{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "index.js": {
      "includeFiles": "node_modules/whatsapp-rust-bridge/**"
    },
    "api/index.js": {
      "includeFiles": "node_modules/whatsapp-rust-bridge/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
