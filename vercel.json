{
  "version": 2,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "node_modules/lru-cache/**",
        "node_modules/socket.io/**",
        "node_modules/engine.io/**",
        "node_modules/socket.io-parser/**",
        "node_modules/engine.io-parser/**",
        "node_modules/socket.io-adapter/**"
      ]
    }
  }
}
